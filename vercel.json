{
    "crons": [
        {
            "path": "/api/daily-whatsapp",
            "schedule": "0 11 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/generate-pix",
            "destination": "/api/generate-pix"
        },
        {
            "source": "/api/send-whatsapp",
            "destination": "/api/send-whatsapp"
        },
        {
            "source": "/api/google-sheets/sync",
            "destination": "/api/sync-sheets"
        },
        {
            "source": "/api/webhooks/mercadopago",
            "destination": "/api/webhooks/mercadopago"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}